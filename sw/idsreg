#!/usr/bin/perl -w
use lib "/usr/local/netfpga/lib/Perl5";
use strict;

my $BASE = 0x2000300;
my $IDS_CPU_POWER_REG    = $BASE + 0x00;
my $IDS_W_DATA_LO_REG    = $BASE + 0x08; 
my $IDS_W_DATA_HI_REG    = $BASE + 0x0C; 
my $IDS_W_CTRL_REG       = $BASE + 0x10; 
my $IDS_IMEM_DATA_REG    = $BASE + 0x14; 
my $IDS_IMEM_CTRL_REG    = $BASE + 0x18; 

my $IDS_HOST_RDATA_LOW_REG  = $BASE + 0x1C;
my $IDS_HOST_RDATA_HIGH_REG = $BASE + 0x20;

sub regwrite {
   my( $addr, $value ) = @_;
   my $cmd = sprintf("regwrite 0x%08x 0x%08x", $addr, $value);
   `$cmd`;
}

sub regread {
   my( $addr ) = @_;
   my $cmd = sprintf("regread 0x%08x", $addr);
   my $out = `$cmd`;
   my @matches = ($out =~ /(0x[0-9a-fA-F]+)/g);
   if (@matches) { return hex($matches[-1]); }
   return 0;
}

sub write_single_imem {
   my ($addr, $hex_str) = @_;
   $hex_str =~ s/^0x//i;
   my $data = hex($hex_str);
   regwrite($IDS_IMEM_DATA_REG, $data);
   my $ctrl_val = 0x80000000 | ($addr & 0x3F);
   regwrite($IDS_IMEM_CTRL_REG, $ctrl_val);
   regwrite($IDS_IMEM_CTRL_REG, 0x00000000);
}

sub write_single_weight {
   my ($addr, $hex_str) = @_;
   $hex_str =~ s/^0x//i;
   $hex_str = sprintf("%016s", $hex_str);
   $hex_str =~ tr/ /0/;
   my $hi = hex(substr($hex_str, 0, 8));
   my $lo = hex(substr($hex_str, 8, 8));
   regwrite($IDS_W_DATA_LO_REG, $lo);
   regwrite($IDS_W_DATA_HI_REG, $hi);
   my $ctrl_val = 0x80000000 | ($addr & 0x3F);
   regwrite($IDS_W_CTRL_REG, $ctrl_val);
   regwrite($IDS_W_CTRL_REG, 0x00000000);
}

sub load_hardcoded_program {
   print "Loading instructions...\n";
   write_single_imem(0,  "0E700000"); write_single_imem(1,  "0E100003"); write_single_imem(2,  "9E17FF01");
   write_single_imem(3,  "0E100126"); write_single_imem(4,  "9E17FF02"); write_single_imem(5,  "0E100001");
   write_single_imem(6,  "9E17FF00"); write_single_imem(7,  "8E27FF03"); write_single_imem(8,  "6E220001");
   write_single_imem(9,  "4E020000"); write_single_imem(10, "A100FFFC"); write_single_imem(11, "0E100126");
   write_single_imem(12, "9E17FF01"); write_single_imem(13, "0E100134"); write_single_imem(14, "9E17FF02");
   write_single_imem(15, "0E100002"); write_single_imem(16, "9E17FF00"); write_single_imem(17, "8E27FF03");
   write_single_imem(18, "6E220001"); write_single_imem(19, "4E020000"); write_single_imem(20, "A100FFFC");
   write_single_imem(21, "9E1701FF"); write_single_imem(22, "F0000000");
}

sub load_hardcoded_weights {
   print "Loading weights...\n";
   write_single_weight(0, "ca12cc81e028bbb1"); write_single_weight(1, "0ec8c5677ff6ad0b");
   write_single_weight(2, "e5f7531c1e0d18da"); write_single_weight(3, "11dd20e4a73a2b0f");
