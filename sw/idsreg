   write_single_weight(34, "00000000ffffd985");
   for (my $i=35; $i<64; $i++) { write_single_weight($i, "0000000000000000"); }
}

sub show_status {
   my $low  = regread($IDS_HOST_RDATA_LOW_REG);
   my $high = regread($IDS_HOST_RDATA_HIGH_REG);
   my $tumor = $low & 0x1; my $busy = ($low >> 1) & 0x1;
   my $halt  = ($low >> 2) & 0x1; my $full = $high & 0x1;
   printf("Status: Tumor=%d, Busy=%d, CPU_Halted=%d, FIFO_Full=%d (Raw: Low=0x%x, High=0x%x)\n", 
          $tumor, $busy, $halt, $full, $low, $high);
}

my $cmd = $ARGV[0] || "status";
if ($cmd eq "load") {
   regwrite($IDS_CPU_POWER_REG, 0); 
   load_hardcoded_program();
   load_hardcoded_weights();
   regwrite($IDS_CPU_POWER_REG, 1);
   print "=== Base Data loaded! ===\n=> Now run 'python send_image_udp.py image.hex' to send image and run inference.\n";
} elsif ($cmd eq "status") {
   show_status();
} else {
   print "Usage: ./idsreg [load | status]\n";
}